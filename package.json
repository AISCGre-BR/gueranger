{
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build -w @gueranger/core && npm run build -w @gueranger/mcp",
    "build:core": "npm run build -w @gueranger/core",
    "build:mcp": "npm run build -w @gueranger/mcp",
    "dev:mcp": "npm run dev -w @gueranger/mcp",
    "test": "vitest run",
    "dev:desktop": "npm run build:core && npm run dev -w @gueranger/desktop",
    "build:desktop": "npm run build -w @gueranger/desktop",
    "inspect": "npx @modelcontextprotocol/inspector node packages/mcp/build/server.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
