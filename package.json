{
  "name": "gueranger",
  "version": "0.0.2-alpha",
  "description": "Unified search for digitized Gregorian chant manuscripts across academic databases — MCP server + desktop app",
  "author": "AISCGre Brasil",
  "contributors": ["Gabriel HTB"],
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/AISCGre-BR/gueranger",
  "repository": {
    "type": "git",
    "url": "https://github.com/AISCGre-BR/gueranger.git"
  },
  "bugs": "https://github.com/AISCGre-BR/gueranger/issues",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build -w @gueranger/core && npm run build -w @gueranger/mcp",
    "build:core": "npm run build -w @gueranger/core",
    "build:mcp": "npm run build -w @gueranger/mcp",
    "dev:mcp": "npm run dev -w @gueranger/mcp",
    "test": "vitest run",
    "dev:desktop": "npm run build:core && npm run dev -w @gueranger/desktop",
    "build:desktop": "npm run build -w @gueranger/desktop",
    "inspect": "npx @modelcontextprotocol/inspector node packages/mcp/build/server.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
