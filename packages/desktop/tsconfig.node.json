{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "outDir": "./out"
  },
  "include": ["src/main/**/*", "src/preload/index.ts"],
  "references": [
    { "path": "../core" }
  ]
}
